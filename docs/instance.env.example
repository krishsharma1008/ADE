# ADE instance environment — copy to ~/.combyne/instances/default/.env
# (The server ONLY reads it from that home path; a repo-root .env is ignored.)
#
#   mkdir -p ~/.combyne/instances/default
#   cp docs/instance.env.example ~/.combyne/instances/default/.env
#   # then fill in the secrets below (ask Krish for the team values)
#
# Restart `pnpm dev` after editing.

# --- Central context DB (the shared team memory rail) ---
# Ask the team lead for the real URL + credentials. Omit entirely for
# single-DB local mode (no shared memory).
COMBYNE_CONTEXT_DATABASE_URL=postgres://USER:URLENCODED_PASSWORD@HOST:5432/postgres?sslmode=require

# Real semantic embeddings for memory recall (shared team key).
OPENAI_API_KEY=sk-proj-REPLACE_ME
COMBYNE_EMBEDDING_API_KEY=sk-proj-REPLACE_ME
COMBYNE_VECTOR_SEARCH_ENABLED=true

# --- Git guardrail: agent pushes allowed ONLY to these remotes (globs) ---
# Keeps agents off production orgs; the test mirrors live under krish-buku/*.
COMBYNE_ALLOWED_PUSH_REMOTE_PATTERNS=krish-buku/*

# --- Merge gating + external-merge detection ---
# allow-unknown-ci keeps CI-less repos dashboard-mergeable; remove once the
# mirrors' CI workflows are merged (fs-brick#7, fs-bnpl#4).
COMBYNE_GITHUB_MERGE_ALLOW_UNKNOWN_CI=true
COMBYNE_PR_SWEEP_INTERVAL_MS=60000

# --- Autonomous completion engines (REQUIRED for unattended ticket work) ---
# Usage limit mid-ticket -> run parks (lock held, session preserved) and
# auto-resumes when the window resets. Turn-budget exhaustion with progress
# -> warm continuation instead of a blocked issue.
COMBYNE_USAGE_PAUSE_ENABLED=true
COMBYNE_MAX_TURNS_CONTINUATION_ENABLED=true

# ADE / Combyne environment overrides
#
# Everything here is OPTIONAL in local_trusted mode (the default). The server
# boots with embedded Postgres on :54329, auto-generates a JWT secret, and
# writes state under ~/.combyne. Uncomment only the variables you want to
# override.
#
# NEVER commit a populated copy of this file — it's meant as documentation.

# ─── Server ────────────────────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=3100
# SERVE_UI=true
# UI_DEV_MIDDLEWARE=false
# HEARTBEAT_SCHEDULER_ENABLED=true
# HEARTBEAT_SCHEDULER_INTERVAL_MS=30000
# COMBYNE_ENABLE_COMPANY_DELETION=true
# PR review feedback is held for a human by default: agents are NOT auto-woken to
# rewrite code when a reviewer requests changes. A board member releases it one round
# at a time from the PR panel ("Let agents fix"); the next reviewer round holds again.
# Set this to true to restore the legacy fully-autonomous fix loop instance-wide.
# COMBYNE_PR_FEEDBACK_AUTOPILOT=false
# Autopilot only: cap how many consecutive fix<->review cycles agents may auto-run
# before re-holding for a human (0 disables the cap). Ignored in the default human-gated
# mode, where every round already requires an explicit human click.
# COMBYNE_PR_FEEDBACK_MAX_ROUNDS=3

# ─── Database ──────────────────────────────────────────────────────────────
# Default is embedded Postgres at 127.0.0.1:54329 (macOS + Linux glibc only).
# On Windows or Alpine Linux, set DATABASE_URL to point at an external Postgres:
# DATABASE_URL=postgres://user:password@host:5432/combyne
# COMBYNE_EMBEDDED_POSTGRES_PORT=54329
# COMBYNE_DB_BACKUP_ENABLED=true
# COMBYNE_DB_BACKUP_INTERVAL_MINUTES=60
# COMBYNE_DB_BACKUP_RETENTION_DAYS=30
# COMBYNE_DB_BACKUP_DIR=~/.combyne/backups

# ─── Deployment / Auth ─────────────────────────────────────────────────────
# For single-user local dev, keep local_trusted (no login required).
# Switch to authenticated when you're exposing the server to a network.
# COMBYNE_DEPLOYMENT_MODE=local_trusted
# COMBYNE_DEPLOYMENT_EXPOSURE=private
# COMBYNE_AUTH_BASE_URL_MODE=auto
# COMBYNE_AUTH_PUBLIC_BASE_URL=
# COMBYNE_AUTH_DISABLE_SIGN_UP=false
# COMBYNE_ALLOWED_HOSTNAMES=
# BETTER_AUTH_SECRET=                # required for Docker / authenticated mode
                                     # generate: openssl rand -hex 32

# ─── Secrets ───────────────────────────────────────────────────────────────
# COMBYNE_SECRETS_PROVIDER=local_encrypted
# COMBYNE_SECRETS_STRICT_MODE=false
# COMBYNE_SECRETS_MASTER_KEY_FILE=~/.combyne/secrets/master.key

# ─── Storage ───────────────────────────────────────────────────────────────
# COMBYNE_STORAGE_PROVIDER=local_disk
# COMBYNE_STORAGE_LOCAL_DIR=~/.combyne/storage
# COMBYNE_STORAGE_S3_BUCKET=combyne
# COMBYNE_STORAGE_S3_REGION=us-east-1
# COMBYNE_STORAGE_S3_ENDPOINT=
# COMBYNE_STORAGE_S3_PREFIX=
# COMBYNE_STORAGE_S3_FORCE_PATH_STYLE=false

# ─── Adapter API keys (for CLIs that also accept env creds) ────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# CURSOR_API_KEY=
# GEMINI_API_KEY=

# ─── Shared-context (Phase C) knobs ────────────────────────────────────────
# COMBYNE_MEMORY_MIN_ENTRIES=3
# COMBYNE_RESET_SESSION_ON_ASSIGN=false

# ─── Central context DB (memory layer) ─────────────────────────────────────
# Run the context/memory tables in a SEPARATE PostgreSQL (defaults to DATABASE_URL).
# This is the ONLY shared rail in the local-first model — every teammate's local
# ADE points its memory layer here so context flows across machines.
# COMBYNE_CONTEXT_DATABASE_URL=postgres://user:pass@host:5432/combyne_context
# Refuse to boot if a separate context DB is expected but missing/unreachable
# (instead of silently falling open to the local ops DB). Default false.
# COMBYNE_CONTEXT_REQUIRED=false
# Only the DESIGNATED operator sets this to apply migrations to the SHARED context
# DB (advisory-lock gated). Teammate boots leave it unset → inspect-only, never
# auto-apply to the shared remote. One-shot: COMBYNE_CONTEXT_DB_MIGRATE=true pnpm db:migrate:context
# COMBYNE_CONTEXT_DB_MIGRATE=false
# The team's pinned canonical company UUID for the shared rail. When set, memory
# routes assert the URL :companyId matches it (a mistyped tenant id can't address
# another team's context). '' = unenforced.
# COMBYNE_CONTEXT_COMPANY_ID=
# TEMPORARY end-to-end context-flow tracing for a test pass (grep one issueId to see
# the whole cross-DB lifecycle). Set to 1 during testing; unset for a true no-op.
# Remove all of it later via: grep -rn "CONTEXT-TRACE" server/src
# COMBYNE_CONTEXT_TRACE=0
# Team-shared embedding key for semantic retrieval. Falls back to OPENAI_API_KEY.
# Bodies egress POST-redaction to the provider — see doc/PRIVACY_DISCLOSURE.md.
# COMBYNE_EMBEDDING_API_KEY=
# COMBYNE_EMBEDDING_PROVIDER=openai
# COMBYNE_EMBEDDING_MODEL=text-embedding-3-small
# MUST match the team's canonical shared vector(N) column width. The shared
# embedding_vec column is vector(1536); a different DIM here means this machine's
# vectors are silently dropped (ANN-invisible). Changing it requires a coordinated
# migration that re-creates embedding_vec at the new width across the shared DB.
# COMBYNE_EMBEDDING_DIM=1536
# Turn on real embeddings/ANN retrieval (needs a key; coerced false when unset).
# COMBYNE_VECTOR_SEARCH_ENABLED=true
# Ask-don't-hallucinate gate — ships dark; enable only after calibration.
# COMBYNE_SUFFICIENCY_GATE_ENABLED=false

# ─── Terminal sessions ─────────────────────────────────────────────────────
# Idle timeout (ms) before an unattached terminal session is reaped. Default
# 1800000 (30 min). Legacy COMBYNE_TERMINAL_IDLE_GRACE_MS still honoured.
# COMBYNE_TERMINAL_IDLE_MS=1800000
# How long before reap to emit `{type:"idle_warning"}` to attached WS
# clients so the UI can show a "session closing in N min" banner + a
# Keep-alive button. Default 300000 (5 min); clamped to half of IDLE_MS.
# COMBYNE_TERMINAL_IDLE_WARNING_MS=300000

# ─── License (optional / paid tiers) ───────────────────────────────────────
# COMBYNE_LICENSE_ENABLED=false
# COMBYNE_LICENSE_SUPABASE_URL=
# COMBYNE_LICENSE_SUPABASE_ANON_KEY=
# COMBYNE_LICENSE_HEARTBEAT_INTERVAL_MINUTES=60
# COMBYNE_LICENSE_GRACE_PERIOD_HOURS=24

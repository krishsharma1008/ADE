# ADE / Combyne environment overrides
#
# Everything here is OPTIONAL in local_trusted mode (the default). The server
# boots with embedded Postgres on :54329, auto-generates a JWT secret, and
# writes state under ~/.combyne. Uncomment only the variables you want to
# override.
#
# NEVER commit a populated copy of this file — it's meant as documentation.

# ─── Server ────────────────────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=3100
# SERVE_UI=true
# UI_DEV_MIDDLEWARE=false
# HEARTBEAT_SCHEDULER_ENABLED=true
# HEARTBEAT_SCHEDULER_INTERVAL_MS=30000
# COMBYNE_ENABLE_COMPANY_DELETION=true

# ─── Database ──────────────────────────────────────────────────────────────
# Default is embedded Postgres at 127.0.0.1:54329 (macOS + Linux glibc only).
# On Windows or Alpine Linux, set DATABASE_URL to point at an external Postgres:
# DATABASE_URL=postgres://user:password@host:5432/combyne
# COMBYNE_EMBEDDED_POSTGRES_PORT=54329
# COMBYNE_DB_BACKUP_ENABLED=true
# COMBYNE_DB_BACKUP_INTERVAL_MINUTES=60
# COMBYNE_DB_BACKUP_RETENTION_DAYS=30
# COMBYNE_DB_BACKUP_DIR=~/.combyne/backups

# ─── Deployment / Auth ─────────────────────────────────────────────────────
# For single-user local dev, keep local_trusted (no login required).
# Switch to authenticated when you're exposing the server to a network.
# COMBYNE_DEPLOYMENT_MODE=local_trusted
# COMBYNE_DEPLOYMENT_EXPOSURE=private
# COMBYNE_AUTH_BASE_URL_MODE=auto
# COMBYNE_AUTH_PUBLIC_BASE_URL=
# COMBYNE_AUTH_DISABLE_SIGN_UP=false
# COMBYNE_ALLOWED_HOSTNAMES=
# BETTER_AUTH_SECRET=                # required for Docker / authenticated mode
                                     # generate: openssl rand -hex 32

# ─── Secrets ───────────────────────────────────────────────────────────────
# COMBYNE_SECRETS_PROVIDER=local_encrypted
# COMBYNE_SECRETS_STRICT_MODE=false
# COMBYNE_SECRETS_MASTER_KEY_FILE=~/.combyne/secrets/master.key

# ─── Storage ───────────────────────────────────────────────────────────────
# COMBYNE_STORAGE_PROVIDER=local_disk
# COMBYNE_STORAGE_LOCAL_DIR=~/.combyne/storage
# COMBYNE_STORAGE_S3_BUCKET=combyne
# COMBYNE_STORAGE_S3_REGION=us-east-1
# COMBYNE_STORAGE_S3_ENDPOINT=
# COMBYNE_STORAGE_S3_PREFIX=
# COMBYNE_STORAGE_S3_FORCE_PATH_STYLE=false

# ─── Adapter API keys (for CLIs that also accept env creds) ────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# CURSOR_API_KEY=
# GEMINI_API_KEY=

# ─── Shared-context (Phase C) knobs ────────────────────────────────────────
# COMBYNE_MEMORY_MIN_ENTRIES=3
# COMBYNE_RESET_SESSION_ON_ASSIGN=false

# ─── Terminal sessions ─────────────────────────────────────────────────────
# Idle timeout (ms) before an unattached terminal session is reaped. Default
# 1800000 (30 min). Legacy COMBYNE_TERMINAL_IDLE_GRACE_MS still honoured.
# COMBYNE_TERMINAL_IDLE_MS=1800000

# ─── License (optional / paid tiers) ───────────────────────────────────────
# COMBYNE_LICENSE_ENABLED=false
# COMBYNE_LICENSE_SUPABASE_URL=
# COMBYNE_LICENSE_SUPABASE_ANON_KEY=
# COMBYNE_LICENSE_HEARTBEAT_INTERVAL_MINUTES=60
# COMBYNE_LICENSE_GRACE_PERIOD_HOURS=24
